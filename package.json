{
  "name": "functions",
  "description": "Cloud Functions for Firebase",
  "scripts": {
    "e2e:auth:save": "node tests/playwright/save-storage-state.js",
    "test:e2e:phase1b": "playwright test tests/playwright/phase1b-visited-smoke.spec.js --reporter=list",
    "test:e2e:account-switch": "playwright test tests/playwright/phase3a-account-switch-smoke.spec.js --reporter=list",
    "test:e2e:profile-manage": "playwright test tests/playwright/phase3a-profile-manage-smoke.spec.js --reporter=list",
    "test:e2e:trip-visited": "playwright test tests/playwright/phase3a-trip-planner-visited-smoke.spec.js --reporter=list",
    "test:e2e:settings": "playwright test tests/playwright/phase3a-settings-persistence-smoke.spec.js --reporter=list",
    "test:e2e:smoke": "playwright test tests/playwright/phase1b-visited-smoke.spec.js tests/playwright/phase3a-premium-gating-smoke.spec.js tests/playwright/phase3a-account-switch-smoke.spec.js tests/playwright/phase3a-settings-persistence-smoke.spec.js tests/playwright/phase3a-profile-manage-smoke.spec.js tests/playwright/phase3a-trip-planner-visited-smoke.spec.js --workers=1 --reporter=list",
    "test:e2e:premium": "playwright test tests/playwright/phase3a-premium-gating-smoke.spec.js --reporter=list",
    "test:e2e:entitlement": "playwright test tests/playwright/phase4c-premium-entitlement-smoke.spec.js --reporter=list",
    "test:e2e:global-search": "playwright test tests/playwright/phase4c-global-search-entitlement-smoke.spec.js --reporter=list"
  },
  "dependencies": {
    "@google/generative-ai": "^0.24.1",
    "axios": "^1.15.0",
    "firebase-admin": "^13.8.0",
    "firebase-functions": "^7.2.5",
    "googleapis": "^171.4.0"
  },
  "engines": {
    "node": "20"
  },
  "main": "index.js",
  "private": true,
  "devDependencies": {
    "@playwright/test": "^1.59.1"
  }
}
