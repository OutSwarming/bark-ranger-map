{
  "functions": [
    {
      "source": "functions",
      "codebase": "default",
      "ignore": [
        "node_modules",
        ".git",
        ".secret.local",
        "firebase-debug.log",
        "firebase-debug.*.log",
        "firestore-debug.log",
        "firestore-debug.*.log",
        "*.log",
        ".env",
        ".env.*",
        ".env*"
      ]
    }
  ],
  "firestore": {
    "rules": "firestore.rules"
  },
  "emulators": {
    "auth": {
      "port": 9099
    },
    "functions": {
      "port": 5001
    },
    "firestore": {
      "port": 8080
    }
  },
  "hosting": {
    "public": ".",
    "ignore": [
      "firebase.json",
      ".firebaserc",
      ".firebase",
      ".firebase/**",
      ".git",
      ".git/**",
      ".github",
      ".github/**",
      "**/.*",
      "**/.*/**",
      "**/.DS_Store",
      "**/node_modules/**",
      "node_modules/**",
      "functions/**",
      "raw_trails/**",
      "data/**",
      "scripts/**",
      "legacy/**",
      "tests/**",
      "playwright/**",
      "test-results/**",
      "playwright-report/**",
      "coverage/**",
      "plans/**",
      "docs/**",
      "**/*.md",
      "autopush.sh",
      "firestore.rules",
      "playwright.config.js",
      "package.json",
      "package-lock.json",
      "BarkRangerMap Auth.json",
      "*Service Account*.json",
      "*service-account*.json",
      "*service_account*.json",
      "firebase-debug.log",
      "firebase-debug.*.log",
      "firestore-debug.log",
      "firestore-debug.*.log",
      ".env",
      ".env.*",
      ".env*",
      "*.log"
    ]
  }
}
