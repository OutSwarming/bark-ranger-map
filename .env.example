# Phase 1B signed-in Playwright smoke setup.
# Start a local static server first:
#   python3 -m http.server 4173 --bind localhost
BARK_E2E_BASE_URL=http://localhost:4173/index.html

# This path is under node_modules, which is already gitignored.
# Generate it with:
#   npm run e2e:auth:save
BARK_E2E_STORAGE_STATE=node_modules/.cache/bark-e2e/storage-state.json

# Dedicated Firebase Email/Password test account for storage-state generation.
# Do not commit real credentials.
BARK_E2E_AUTH_EMAIL=phase1b-smoke@example.com
BARK_E2E_AUTH_PASSWORD=replace-with-local-secret

# Optional: pin the smoke suite to a known canonical park id.
# BARK_E2E_TEST_PARK_ID=canonical-park-id
